---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const products = (await getCollection("products")).sort(
  (a, b) => a.data.order - b.data.order,
);

const statusColors: Record<string, string> = {
  released: "#34D399",
  beta: "#FBBF24",
  preview: "#A1A1AA",
};

const platformLabel = (url: string): string => {
  try {
    const host = new URL(url).hostname;
    if (host.includes("obsidian.md")) return "obsidian";
    if (host.includes("npmjs")) return "npm";
    if (host.includes("pypi.org")) return "pypi";
    if (host.includes("crates.io")) return "crates";
    return "pkg";
  } catch {
    return "pkg";
  }
};
---

<BaseLayout title="Products" description="Polished software Jordan Newell ships and stands behind.">
  <header class="products-hero">
    <div class="products-hero-glow"></div>
    <div class="products-hero-content">
      <span class="products-hero-eyebrow">// shipping</span>
      <h1 class="products-hero-title">/products</h1>
      <p class="products-hero-tagline">
        Polished, shipped, supported. Free, open source, built to last.
      </p>
      <p class="products-hero-desc">
        The polished subset of <a href="/projects" class="hero-link">/projects</a>. Each product ships with documentation, long-term support, and a name attached — distinct from the wider bench of work in flight.
      </p>
      <div class="products-hero-stats">
        <span class="stat-pill"><span class="stat-num">1</span> shipped</span>
        <span class="stat-pill"><span class="stat-num">MIT</span> licensed</span>
        <span class="stat-pill"><span class="stat-num">0</span> telemetry</span>
        <span class="stat-pill"><span class="stat-num">2026</span> →</span>
      </div>
    </div>
  </header>

  <div class="space-y-4">
    {products.map((p) => (
      <a
        href={`/products/${p.id}/`}
        class="product-card block border border-border rounded-lg p-6 hover:border-border-light hover:bg-bg-card-hover transition-colors"
      >
        <div class="product-card-grid">
          {p.data.logo && (
            <div class="product-card-logo">
              <img src={`${p.data.logo}?v=4`} alt={`${p.data.title} logo`} width="56" height="56" loading="lazy" />
            </div>
          )}
          <div class="product-card-body">
            <div class="flex items-baseline justify-between mb-2 gap-4">
              <h2 class="font-display font-bold text-2xl">{p.data.title}</h2>
              <span
                class="text-xs font-mono whitespace-nowrap uppercase tracking-wider"
                style={`color: ${statusColors[p.data.status] ?? "#A1A1AA"}`}
              >
                {p.data.status}
              </span>
            </div>
            <p class="font-display font-medium text-lg text-green mb-2">{p.data.tagline}</p>
            <p class="text-fg-secondary text-sm leading-relaxed mb-4">{p.data.description}</p>
            <div class="flex flex-wrap items-center gap-2">
              {p.data.platform && (
                <span class="text-xs font-mono px-2 py-0.5 rounded border border-border text-violet">
                  {platformLabel(p.data.platform.url)} ↗
                </span>
              )}
              {p.data.stats.slice(0, 4).map((s) => (
                <span class="text-xs font-mono text-fg-muted">
                  <span class="text-fg-secondary">{s.v}</span> {s.k}
                </span>
              ))}
            </div>
          </div>
        </div>
      </a>
    ))}
    {products.length === 0 && (
      <p class="text-fg-muted italic">No products listed yet — check back soon.</p>
    )}
  </div>
</BaseLayout>

<style>
  /* HERO */
  .products-hero {
    position: relative;
    padding: 2.5rem 2rem;
    margin-bottom: 2.5rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    overflow: hidden;
  }
  .products-hero-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 70% 60% at 100% 0%, color-mix(in srgb, var(--color-violet) 22%, transparent), transparent 60%),
      radial-gradient(ellipse 60% 70% at 0% 100%, color-mix(in srgb, var(--color-green) 12%, transparent), transparent 55%);
  }
  .products-hero-content {
    position: relative;
    z-index: 1;
  }
  .products-hero-eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-green);
    margin-bottom: 0.75rem;
  }
  .products-hero-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2.25rem, 5vw, 3.25rem);
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--color-fg);
    margin-bottom: 0.75rem;
  }
  .products-hero-tagline {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    color: var(--color-green);
    line-height: 1.3;
    margin-bottom: 0.625rem;
    max-width: 60ch;
  }
  .products-hero-desc {
    font-size: 1rem;
    color: var(--color-fg-secondary);
    line-height: 1.65;
    max-width: 65ch;
    margin-bottom: 1.5rem;
  }
  .hero-link {
    color: var(--color-green);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .hero-link:hover {
    color: color-mix(in srgb, var(--color-green) 80%, transparent);
  }
  .products-hero-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
  }
  .stat-pill {
    display: inline-flex;
    align-items: baseline;
    gap: 0.375rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.375rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    background: color-mix(in srgb, var(--color-bg) 50%, transparent);
  }
  .stat-num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--color-fg);
    letter-spacing: 0;
    text-transform: none;
  }

  /* PRODUCT CARD GRID */
  .product-card-grid {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 1.25rem;
    align-items: start;
  }
  @media (max-width: 480px) {
    .product-card-grid {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }
    .product-card-logo {
      width: 48px;
      height: 48px;
    }
  }
  .product-card-logo {
    width: 56px;
    height: 56px;
    flex-shrink: 0;
  }
  .product-card-logo img {
    width: 100%;
    height: 100%;
    display: block;
  }
  .product-card:hover .product-card-logo {
    filter: drop-shadow(0 2px 12px color-mix(in srgb, var(--color-violet) 30%, transparent));
  }
</style>
