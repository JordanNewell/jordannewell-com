---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects"))
  .sort((a, b) => a.data.order - b.data.order);

const statusColors: Record<string, string> = {
  active: "#34D399",
  shipped: "#60A5FA",
  exploratory: "#A1A1AA",
  "venture-track": "#FBBF24",
};
---

<BaseLayout title="Projects" description="What I've built, in public.">
  <header class="mb-10">
    <h1 class="font-display font-bold text-4xl mb-3">/projects</h1>
    <p class="text-fg-secondary">
      Real software and systems I've shipped or am actively building.
    </p>
  </header>

  <div class="space-y-4">
    {projects.map((p) => (
      <a
        href={`/projects/${p.id}/`}
        class="block border border-border rounded-lg p-5 hover:border-border-light hover:bg-bg-card-hover transition-colors"
      >
        <div class="flex items-baseline justify-between mb-1 gap-4">
          <h2 class="font-display font-bold text-lg">{p.data.title}</h2>
          <span
            class="text-xs font-mono whitespace-nowrap uppercase tracking-wider"
            style={`color: ${statusColors[p.data.status] ?? "#A1A1AA"}`}
          >
            {p.data.status}
          </span>
        </div>
        <p class="text-fg-secondary text-sm">{p.data.description}</p>
      </a>
    ))}
  </div>
</BaseLayout>
