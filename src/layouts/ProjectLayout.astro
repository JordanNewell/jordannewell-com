---
import BaseLayout from "./BaseLayout.astro";
import TagPill from "../components/TagPill.astro";
import PostShare from "../components/PostShare.astro";
import { creativeWorkSchema } from "../lib/schema";
import { SITE } from "../lib/site";
import { getCollection, type CollectionEntry } from "astro:content";

const { project } = Astro.props as { project: CollectionEntry<"projects"> };
const { title, description, status, repo, liveUrl, tags } = project.data;

const shareUrl = `${SITE.url}/projects/${project.id}/`;

const allPosts = await getCollection("posts");
const relatedPosts = allPosts
  .filter((p) => p.data.project === project.id)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const statusColors: Record<string, string> = {
  active: "text-green",
  shipped: "text-blue",
  exploratory: "text-amber",
  "venture-track": "text-violet",
  deprecated: "text-fg-muted",
};

const schema = [
  creativeWorkSchema({
    name: title,
    description,
    slug: project.id,
    repo,
    status,
    tags,
  }),
];
---

<BaseLayout title={title} description={description} schema={schema}>
  <article class="prose">
    <header class="project-hero">
      <div class="project-hero-glow"></div>
      <div class="project-hero-content">
        <div class="project-hero-badges">
          <span class={`status-pill ${statusColors[status]}`}>{status}</span>
          {tags.map((tag) => <TagPill tag={tag} />)}
        </div>
        <h1 class="project-hero-title">{title}</h1>
        <p class="project-hero-desc">{description}</p>
        {(repo || liveUrl) && (
          <div class="project-hero-links">
            {repo && <a href={repo} class="project-link" target="_blank" rel="noopener">source ↗</a>}
            {liveUrl && <a href={liveUrl} class="project-link" target="_blank" rel="noopener">live ↗</a>}
          </div>
        )}
      </div>
    </header>
    {project.data.facts && project.data.facts.length > 0 && (
      <section class="mb-8">
        <h2 class="font-mono text-xs uppercase tracking-widest text-fg-muted mb-3">At a glance</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
          {project.data.facts.map((fact) => (
            <div class="border border-border rounded-md px-3 py-2 hover:border-border-light transition-colors">
              <div class="font-mono text-xs uppercase tracking-wider text-fg-muted">{fact.k}</div>
              <div class="font-display font-semibold text-sm">{fact.v}</div>
            </div>
          ))}
        </div>
      </section>
    )}
    {project.data.highlights && project.data.highlights.length > 0 && (
      <section class="mb-8">
        <h2 class="font-mono text-xs uppercase tracking-widest text-fg-muted mb-3">Highlights</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
          {project.data.highlights.map((h) => (
            <div class="border border-border rounded-md px-4 py-3 hover:border-border-light hover:bg-bg-card-hover transition-colors">
              <div class="font-display font-semibold text-base mb-1">{h.title}</div>
              <div class="text-sm text-fg-secondary leading-relaxed">{h.body}</div>
            </div>
          ))}
        </div>
      </section>
    )}
    {project.data.stack && project.data.stack.length > 0 && (
      <section class="mb-8">
        <h2 class="font-mono text-xs uppercase tracking-widest text-fg-muted mb-3">Stack</h2>
        <div class="flex flex-wrap gap-1.5">
          {project.data.stack.map((s) => (
            <span class="font-mono text-xs px-2.5 py-0.5 rounded-full border border-border-light text-fg-secondary">
              {s}
            </span>
          ))}
        </div>
      </section>
    )}
    <slot />
    {relatedPosts.length > 0 && (
      <section class="mt-12">
        <h2 class="font-mono text-xs uppercase tracking-widest text-fg-muted mb-3">Related</h2>
        <ul class="divide-y divide-border">
          {relatedPosts.map((p) => (
            <li>
              <a
                href={`/posts/${p.id}/`}
                class="flex items-baseline justify-between gap-4 py-2 hover:text-green transition-colors"
              >
                <span class="text-sm">{p.data.title}</span>
                <span class="font-mono text-xs text-fg-muted whitespace-nowrap">
                  {p.data.pubDate.toISOString().slice(0, 10)}
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}
    <PostShare url={shareUrl} title={title} />
  </article>
</BaseLayout>

<style>
  .project-hero {
    position: relative;
    padding: 2rem 1.75rem;
    margin-bottom: 2.5rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    overflow: hidden;
  }
  .project-hero-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 70% 60% at 100% 0%, color-mix(in srgb, var(--color-blue) 22%, transparent), transparent 60%),
      radial-gradient(ellipse 60% 70% at 0% 100%, color-mix(in srgb, var(--color-green) 12%, transparent), transparent 55%);
  }
  .project-hero-content {
    position: relative;
    z-index: 1;
  }
  .project-hero-badges {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.625rem;
    margin-bottom: 1rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }
  .project-hero-badges :global(.status-pill),
  .project-hero-badges .status-pill {
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.25rem 0.625rem;
    border-radius: 0.25rem;
    background: color-mix(in srgb, var(--color-bg) 50%, transparent);
    border: 1px solid var(--color-border);
  }
  .project-hero-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--color-fg);
    margin-bottom: 0.625rem;
  }
  .project-hero-desc {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.125rem;
    color: var(--color-fg-secondary);
    line-height: 1.5;
    max-width: 65ch;
    margin-bottom: 1rem;
  }
  .project-hero-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 0.875rem;
  }
  .project-link {
    color: var(--color-green);
    text-decoration: none;
  }
  .project-link:hover { text-decoration: underline; text-underline-offset: 2px; }
</style>
