---
import { SITE } from "../lib/site";
const year = new Date().getFullYear();
---

<footer class="border-t border-border mt-24">
  <div class="max-w-prose mx-auto px-5 py-8 text-center text-sm text-fg-muted font-mono">
    <p class="mb-2">
      <a href="https://x.com/newellops" target="_blank" rel="noopener" class="hover:text-green">x</a>
      <span class="mx-2">·</span>
      <a href="https://bsky.app/profile/jordannewell.com" target="_blank" rel="noopener" class="hover:text-green">bluesky</a>
      <span class="mx-2">·</span>
      <a href="https://github.com/jordannewell" target="_blank" rel="noopener" class="hover:text-green">github</a>
      <span class="mx-2">·</span>
      <a href="mailto:hello@jordannewell.com" class="hover:text-green">email</a>
    </p>
    <p class="mb-2">
      <a href="/rss.xml" class="hover:text-green">rss</a>
      <span class="mx-2">·</span>
      <a href="/feed.json" class="hover:text-green">json</a>
      <span class="mx-2">·</span>
      <a href="/llms.txt" class="hover:text-green">llms.txt</a>
      <span class="mx-2">·</span>
      <a href="https://github.com/JordanNewell/jordannewell-blog" target="_blank" rel="noopener" class="hover:text-green">source</a>
    </p>
    <p class="mb-3">
      <a href="https://status.jordannewell.com" class="status-badge inline-flex items-center gap-1.5 hover:text-green" data-status-badge target="_blank" rel="noopener" aria-label="System status">
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-fg-muted transition-colors" data-status-dot></span>
        <span data-status-text>Checking systems…</span>
      </a>
    </p>
    <p>© {year} {SITE.author.name} · <a href="/license" class="hover:text-green">license</a></p>
  </div>
</footer>

<style is:global>
  [data-status-badge] { transition: color 0.15s ease; }
  [data-status-badge] [data-status-dot] { transition: background 0.3s ease, box-shadow 0.3s ease; }

  [data-status-badge].is-up [data-status-dot] {
    background: #34D399;
    box-shadow: 0 0 8px rgba(52,211,153,0.5);
  }
  [data-status-badge].is-up [data-status-text] { color: #34D399; }

  [data-status-badge].is-down [data-status-dot] {
    background: #F87171;
    box-shadow: 0 0 8px rgba(248,113,113,0.4);
  }
  [data-status-badge].is-down [data-status-text] { color: #F87171; }
</style>

<script src="/js/main.js" defer></script>
