---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const allContributions = await getCollection("contributions");
const contributions = [...allContributions].sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const statusLabel: Record<string, string> = {
  shipped: "Shipped",
  open: "Open",
  investigating: "Investigating",
  "closed-wontfix": "Closed (won't fix)",
};
const statusClass: Record<string, string> = {
  shipped: "text-green border-green/40",
  open: "text-cyan border-cyan/40",
  investigating: "text-amber border-amber/40",
  "closed-wontfix": "text-fg-muted border-fg-muted/40",
};

const countBy = (status: string) => allContributions.filter((c) => c.data.status === status).length;
const projects = [...new Set(allContributions.map((c) => c.data.project))];
---

<BaseLayout title="Contributions" description="Verifiable OSS contributions — bugs filed, PRs merged, community engagement.">
  <header class="contributions-hero">
    <div class="contributions-hero-glow"></div>
    <div class="contributions-hero-content">
      <span class="contributions-hero-eyebrow">// giving back</span>
      <h1 class="contributions-hero-title">/contributions</h1>
      <p class="contributions-hero-tagline">
        Verifiable OSS work. Bug reports filed, PRs merged, community engaged.
      </p>
      <p class="contributions-hero-desc">
        Most "builders" in the AI era are pure consumers — running closed-source wrappers on top of other people's work. This page is the differentiator. Including the open and unresolved items; survivorship bias is bad faith.
      </p>
      <div class="contributions-hero-stats">
        <span class="stat-pill"><span class="stat-num">{allContributions.length}</span> total</span>
        <span class="stat-pill"><span class="stat-num">{countBy("shipped")}</span> shipped</span>
        <span class="stat-pill"><span class="stat-num">{countBy("open") + countBy("investigating")}</span> open</span>
        <span class="stat-pill"><span class="stat-num">{projects.length}</span> projects</span>
      </div>
    </div>
  </header>

  <div class="space-y-5">
    {contributions.map((c) => (
      <article class="border-l-2 border-cyan pl-4">
        <div class="text-xs font-mono text-fg-muted mb-1 flex flex-wrap items-center gap-x-2 gap-y-1">
          <span>
            {c.data.date.toLocaleDateString("en-US", { year: "numeric", month: "short", timeZone: "UTC" })}
            · <span class="text-cyan">{c.data.type}</span>
            · {c.data.project}
          </span>
          <span class={`px-1.5 py-0.5 border rounded-sm uppercase tracking-wide text-[10px] ${statusClass[c.data.status]}`}>
            {statusLabel[c.data.status]}
          </span>
        </div>
        <h2 class="font-display font-semibold mb-1">
          <a href={c.data.url} class="hover:text-cyan">{c.data.title}</a>
        </h2>
        <p class="text-sm text-fg-secondary mb-1">{c.data.description}</p>
        <p class="text-xs font-mono text-green">→ {c.data.outcome}</p>
      </article>
    ))}
  </div>

  <style>
    .contributions-hero {
      position: relative;
      padding: 2.5rem 2rem;
      margin-bottom: 2.5rem;
      background: var(--color-bg-card);
      border: 1px solid var(--color-border);
      border-radius: 0.75rem;
      overflow: hidden;
    }
    .contributions-hero-glow {
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        radial-gradient(ellipse 70% 60% at 100% 0%, color-mix(in srgb, var(--color-cyan) 22%, transparent), transparent 60%),
        radial-gradient(ellipse 60% 70% at 0% 100%, color-mix(in srgb, var(--color-green) 12%, transparent), transparent 55%);
    }
    .contributions-hero-content { position: relative; z-index: 1; }
    .contributions-hero-eyebrow {
      display: inline-block;
      font-family: var(--font-mono);
      font-size: 0.75rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--color-green);
      margin-bottom: 0.75rem;
    }
    .contributions-hero-title {
      font-family: var(--font-display);
      font-weight: 800;
      font-size: clamp(2.25rem, 5vw, 3.25rem);
      line-height: 1;
      letter-spacing: -0.03em;
      color: var(--color-fg);
      margin-bottom: 0.75rem;
    }
    .contributions-hero-tagline {
      font-family: var(--font-display);
      font-weight: 500;
      font-size: clamp(1.125rem, 2vw, 1.375rem);
      color: var(--color-cyan);
      line-height: 1.3;
      margin-bottom: 0.625rem;
      max-width: 60ch;
    }
    .contributions-hero-desc {
      font-size: 1rem;
      color: var(--color-fg-secondary);
      line-height: 1.65;
      max-width: 65ch;
      margin-bottom: 1.5rem;
    }
    .contributions-hero-stats {
      display: flex;
      flex-wrap: wrap;
      gap: 0.625rem;
    }
    .stat-pill {
      display: inline-flex;
      align-items: baseline;
      gap: 0.375rem;
      font-family: var(--font-mono);
      font-size: 0.75rem;
      color: var(--color-fg-muted);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      padding: 0.375rem 0.75rem;
      border: 1px solid var(--color-border);
      border-radius: 0.25rem;
      background: color-mix(in srgb, var(--color-bg) 50%, transparent);
    }
    .stat-num {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 0.9rem;
      color: var(--color-fg);
      letter-spacing: 0;
      text-transform: none;
    }
  </style>
</BaseLayout>
