---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 — Not Found" description="Page not found.">
  <header class="mb-10">
    <h1 class="font-display font-bold text-4xl mb-3">/404</h1>
    <p class="text-fg-secondary">
      That URL doesn't go anywhere. Try the <a href="/" class="text-green hover:underline">homepage</a>,
      <a href="/posts/" class="text-green hover:underline">posts</a>,
      <a href="/about/" class="text-green hover:underline">about</a>, or
      <a href="/now/" class="text-green hover:underline">/now</a>.
    </p>
  </header>
</BaseLayout>
