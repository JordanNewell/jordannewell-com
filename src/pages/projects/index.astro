---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Projects" description="What I've built, in public.">
  <header class="mb-10">
    <h1 class="font-display font-bold text-4xl mb-3">/projects</h1>
    <p class="text-fg-secondary">
      Real software and systems I've shipped or am actively building.
    </p>
  </header>

  <div class="border border-dashed border-border rounded-lg p-10 text-center">
    <p class="font-mono text-fg-muted text-sm mb-2">coming soon</p>
    <p class="text-fg-secondary">
      Project pages are being written. In the meantime, the
      <a href="/posts/" class="text-green hover:underline">blog</a>
      covers what's currently shipping, and
      <a href="/contributions/" class="text-green hover:underline">/contributions</a>
      logs verifiable OSS work.
    </p>
  </div>
</BaseLayout>
