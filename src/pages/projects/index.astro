---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import TagPill from "../../components/TagPill.astro";

const projects = (await getCollection("projects"))
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Projects" description="What I've built, in public.">
  <header class="mb-10">
    <h1 class="font-display font-bold text-4xl mb-3">/projects</h1>
    <p class="text-fg-secondary">
      Real software and systems I've shipped or am actively building. Each has its own page;
      posts that reference a project link back to it.
    </p>
  </header>
  <div class="space-y-6">
    {projects.map((project) => (
      <article class="border border-border rounded-lg p-6 hover:border-border-light transition-colors">
        <div class="flex items-center justify-between mb-2">
          <h2 class="font-display font-bold text-xl">
            <a href={`/projects/${project.id}`} class="hover:text-green">{project.data.title}</a>
          </h2>
          <span class="font-mono text-xs text-fg-muted">{project.data.status}</span>
        </div>
        <p class="text-fg-secondary text-sm mb-3">{project.data.description}</p>
        <div class="flex gap-2">
          {project.data.tags.map((tag) => <TagPill tag={tag} />)}
        </div>
      </article>
    ))}
  </div>
</BaseLayout>
