---
import { SITE } from "../lib/site";
const year = new Date().getFullYear();
---

<footer class="border-t border-border mt-24">
  <div class="max-w-prose mx-auto px-5 py-8 text-center text-sm text-fg-muted font-mono">
    <p class="mb-2">
      <a href="https://github.com/jordannewell" target="_blank" rel="noopener" class="hover:text-green">github</a>
      <span class="mx-2">·</span>
      <a href="mailto:hello@jordannewell.com" class="hover:text-green">hello</a>
    </p>
    <p class="mb-2">
      <a href="/rss.xml" class="hover:text-green">rss</a>
      <span class="mx-2">·</span>
      <a href="/feed.json" class="hover:text-green">json</a>
      <span class="mx-2">·</span>
      <a href="/llms.txt" class="hover:text-green">llms.txt</a>
      <span class="mx-2">·</span>
      <a href="https://github.com/JordanNewell/jordannewell-com" target="_blank" rel="noopener" class="hover:text-green">source</a>
    </p>
    <p class="mb-3">© {year} {SITE.author.name} <span aria-hidden="true">❤️</span> <a href="/license" class="hover:text-green">license</a></p>
    <p class="mb-3">
      <a href="https://status.jordannewell.com" class="status-badge inline-flex items-center gap-1.5 hover:text-green is-down" target="_blank" rel="noopener" aria-label="System status">
        <span class="inline-block w-1.5 h-1.5 rounded-full" style="background: #FBBF24; box-shadow: 0 0 8px rgba(251,191,36,0.4);"></span>
        <span style="color: #FBBF24;">1 of 5 services degraded</span>
      </a>
    </p>
  </div>
</footer>

<!-- Status badge static — Kuma back online 2026-07-22, 1 of 5 services still investigating. Re-enable JS fetch for live updates. -->
<!-- Support CTAs live in <SupportCTA /> above the footer (two big split-hero cards: BMC + GitHub Sponsors). -->
