---
import BaseLayout from "./BaseLayout.astro";
import PostShare from "../components/PostShare.astro";
import { softwareApplicationSchema } from "../lib/schema";
import { SITE } from "../lib/site";
import { getCollection, type CollectionEntry } from "astro:content";

const { product } = Astro.props as { product: CollectionEntry<"products"> };
const {
  title,
  tagline,
  description,
  status,
  repo,
  homepage,
  logo,
  platform,
  shipDate,
  install,
  pricing,
  license,
  stats,
  features,
  comparison,
  faq,
  privacy,
  ogImage,
} = product.data;

const shareUrl = `${SITE.url}/products/${product.id}/`;
const canonicalOg = ogImage ?? `/og-curtis-ai-chat.png`;

const statusStyles: Record<string, string> = {
  released: "text-green border-green/40 bg-green/10",
  beta: "text-amber border-amber/40 bg-amber/10",
  preview: "text-fg-secondary border-border",
};

const installIcons: Record<string, string> = {
  directory: "Storefront",
  brat: "TestTube",
  npm: "Package",
  pip: "Package",
  manual: "Download",
  homebrew: "Cup",
  other: "ExternalLink",
};

const schema = [
  softwareApplicationSchema({
    name: title,
    description,
    slug: product.id,
    repo,
    homepage,
    license,
    shipDate,
    pricing,
    faq,
  }),
];
---

<BaseLayout title={title} description={description} schema={schema} ogImage={canonicalOg}>
  <article class="product">
    <!-- HERO -->
    <header class="hero">
      <div class="hero-glow"></div>
      {logo && (
        <div class="hero-wordmark">
          <img src={`${logo}?v=4`} alt="" class="wordmark-logo" width="60" height="60" loading="eager" />
          <h1 class="wordmark-text">
            Curtis <span class="dim">AI Chat</span>
          </h1>
        </div>
      )}
      <div class="hero-badges">
        <span class={`status-pill ${statusStyles[status]}`}>{status}</span>
        {platform && (
          <a
            href={platform.url}
            target="_blank"
            rel="noopener"
            class="meta-pill meta-pill-link"
            title={`Runs on ${platform.name}`}
          >
            {platform.name.toLowerCase()} ↗
          </a>
        )}
        <span class="meta-pill">{license}</span>
        <span class="meta-pill">shipped {shipDate.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric", timeZone: "UTC" })}</span>
      </div>
      <p class="hero-tagline">{tagline}</p>
      <p class="hero-desc">{description}</p>
      <div class="hero-cta">
        {install.filter((i) => i.kind === "directory" || i.kind === "brat" || i.kind === "npm" || i.kind === "pip").slice(0, 1).map((i) => (
          <a class="cta cta-primary" href={i.href ?? repo} target="_blank" rel="noopener">
            Install {i.label}
          </a>
        ))}
        <a class="cta cta-secondary" href={repo} target="_blank" rel="noopener">View source ↗</a>
        {homepage && (
          <a class="cta cta-tertiary" href={homepage} target="_blank" rel="noopener">Homepage ↗</a>
        )}
      </div>
      {stats.length > 0 && (
        <div class="hero-stats">
          {stats.map((s) => (
            <div class="stat">
              <div class="stat-v">{s.v}</div>
              <div class="stat-k">{s.k}</div>
            </div>
          ))}
        </div>
      )}
    </header>

    <div class="divider"></div>

    <!-- BODY (custom markdown from content) -->
    <div class="product-body prose">
      <slot />
    </div>

    <!-- INSTALL -->
    {install.length > 0 && (
      <section class="install-section">
        <h2 class="section-h">Install</h2>
        <div class={`install-grid install-grid-${Math.min(install.length, 3)}`}>
          {install.map((i) => (
            <div class="install-card">
              <div class="install-label">{i.label}</div>
              {i.href ? (
                <a href={i.href} target="_blank" rel="noopener" class="install-link">
                  {i.detail ?? i.href.replace(/^https?:\/\//, "").replace(/\/$/, "")} ↗
                </a>
              ) : (
                <div class="install-detail">{i.detail}</div>
              )}
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- FEATURES -->
    {features.length > 0 && (
      <section class="features-section">
        <h2 class="section-h">Features</h2>
        <div class="features-grid">
          {features.map((f) => (
            <div class="feature-card">
              {f.icon && <div class="feature-icon">{f.icon}</div>}
              <h3 class="feature-title">{f.title}</h3>
              <p class="feature-body">{f.body}</p>
              {f.docUrl && (
                <a href={f.docUrl} target="_blank" rel="noopener" class="feature-link">Learn more ↗</a>
              )}
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- COMPARISON -->
    {comparison && (
      <section class="comparison-section">
        <h2 class="section-h">{comparison.title ?? "How it compares"}</h2>
        <div class="table-wrap">
          <table class="comparison-table">
            <thead>
              <tr>
                <th></th>
                {comparison.columns.map((c) => <th>{c}</th>)}
              </tr>
            </thead>
            <tbody>
              {comparison.rows.map((row) => (
                <tr>
                  <td class="row-label">{row.label}</td>
                  {row.cells.map((cell) => <td>{cell}</td>)}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    )}

    <!-- PRIVACY -->
    {privacy && (
      <section class="privacy-section">
        <h2 class="section-h">Privacy</h2>
        <p class="privacy-body">{privacy}</p>
      </section>
    )}

    <!-- FAQ -->
    {faq.length > 0 && (
      <section class="faq-section">
        <h2 class="section-h">FAQ</h2>
        <dl class="faq-list">
          {faq.map((item) => (
            <div class="faq-item">
              <dt class="faq-q">{item.q}</dt>
              <dd class="faq-a">{item.a}</dd>
            </div>
          ))}
        </dl>
      </section>
    )}

    <!-- FOOTER CTA -->
    <footer class="product-footer">
      <div class="footer-cta">
        <h2 class="footer-h">Use {title}?</h2>
        <p class="footer-p">
          Star the repo, file issues, sponsor ongoing development. Every feature is free and open source forever.
        </p>
        <div class="footer-links">
          <a href={repo} target="_blank" rel="noopener" class="cta cta-secondary">Source ↗</a>
          <a href="https://www.buymeacoffee.com/jordannewell" target="_blank" rel="noopener" class="cta cta-tertiary">Buy me a coffee</a>
          <a href="https://github.com/sponsors/jordannewell" target="_blank" rel="noopener" class="cta cta-tertiary">Sponsor on GitHub</a>
        </div>
      </div>
    </footer>
    <PostShare url={shareUrl} title={title} />
  </article>
</BaseLayout>

<style>
  .product {
    max-width: 60rem;
    margin-inline: auto;
  }

  /* HERO */
  .hero {
    position: relative;
    padding: 2.5rem 2rem 2.5rem;
    margin-block: 0 3rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    overflow: hidden;
  }
  .hero-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 70% 60% at 100% 0%, color-mix(in srgb, var(--color-violet) 22%, transparent), transparent 60%),
      radial-gradient(ellipse 60% 70% at 0% 100%, color-mix(in srgb, var(--color-green) 12%, transparent), transparent 55%);
  }
  .hero > * {
    position: relative;
    z-index: 1;
  }
  .hero-wordmark {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }
  .wordmark-logo {
    width: 60px;
    height: 60px;
    flex-shrink: 0;
    filter: drop-shadow(0 4px 20px color-mix(in srgb, var(--color-violet) 40%, transparent));
  }
  .wordmark-text {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2rem, 4vw, 2.75rem);
    line-height: 1;
    letter-spacing: -0.025em;
    color: var(--color-fg);
    margin: 0;
  }
  .wordmark-text .dim {
    color: var(--color-fg-muted);
    font-weight: 500;
    letter-spacing: -0.015em;
  }
  .hero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }
  .status-pill, .meta-pill {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.25rem 0.625rem;
    border-radius: 0.25rem;
    border: 1px solid var(--color-border);
  }
  .meta-pill {
    color: var(--color-fg-secondary);
  }
  .meta-pill-link {
    color: var(--color-violet);
    text-decoration: none;
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .meta-pill-link:hover {
    border-color: var(--color-violet);
    color: color-mix(in srgb, var(--color-violet) 80%, white);
  }
  .hero-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
  }
  .hero-tagline {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.25rem, 2.5vw, 1.5rem);
    color: var(--color-green);
    margin-bottom: 1rem;
    line-height: 1.3;
  }
  .hero-desc {
    font-size: 1.125rem;
    color: var(--color-fg-secondary);
    line-height: 1.65;
    max-width: 50ch;
    margin-bottom: 2rem;
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }
  .cta {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    padding: 0.625rem 1.25rem;
    border-radius: 0.375rem;
    border: 1px solid transparent;
    text-decoration: none;
    transition: all 0.15s ease;
  }
  .cta-primary {
    background: var(--color-green);
    color: var(--color-bg);
    font-weight: 600;
  }
  .cta-primary:hover {
    background: color-mix(in srgb, var(--color-green) 85%, white);
    transform: translateY(-1px);
  }
  .cta-secondary {
    border-color: var(--color-border-light);
    color: var(--color-fg);
  }
  .cta-secondary:hover {
    border-color: var(--color-green);
    color: var(--color-green);
  }
  .cta-tertiary {
    color: var(--color-fg-secondary);
  }
  .cta-tertiary:hover {
    color: var(--color-green);
  }
  .hero-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 1rem;
    padding: 1.25rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
  }
  .stat-v {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.5rem;
    color: var(--color-fg);
  }
  .stat-k {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-fg-muted);
    margin-top: 0.125rem;
  }

  /* DIVIDER */
  .divider {
    height: 1px;
    margin-block: 1rem 3rem;
    background: linear-gradient(90deg,
      color-mix(in srgb, var(--color-green) 60%, transparent),
      color-mix(in srgb, var(--color-green) 20%, transparent) 30%,
      transparent 70%);
  }

  /* SECTION HEADINGS */
  .section-h {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-fg-muted);
    margin-bottom: 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .product-body {
    margin-bottom: 3rem;
  }

  /* INSTALL */
  .install-section { margin-bottom: 3rem; }
  .install-grid {
    display: grid;
    gap: 0.75rem;
  }
  .install-grid-1 { grid-template-columns: 1fr; }
  .install-grid-2 { grid-template-columns: repeat(2, 1fr); }
  .install-grid-3 { grid-template-columns: repeat(3, 1fr); }
  @media (max-width: 640px) {
    .install-grid-2, .install-grid-3 { grid-template-columns: 1fr; }
  }
  .install-card {
    padding: 1rem 1.25rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
  }
  .install-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-fg-muted);
    margin-bottom: 0.5rem;
  }
  .install-link, .install-detail {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-green);
    word-break: break-all;
  }
  .install-detail { color: var(--color-fg-secondary); }

  /* FEATURES */
  .features-section { margin-bottom: 3rem; }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 0.75rem;
  }
  .feature-card {
    padding: 1.25rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    transition: border-color 0.15s ease, background 0.15s ease;
  }
  .feature-card:hover {
    border-color: var(--color-border-light);
    background: var(--color-bg-card-hover);
  }
  .feature-icon {
    font-size: 1.5rem;
    line-height: 1;
    margin-bottom: 0.75rem;
  }
  .feature-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.0625rem;
    color: var(--color-fg);
    margin-bottom: 0.375rem;
  }
  .feature-body {
    font-size: 0.9375rem;
    color: var(--color-fg-secondary);
    line-height: 1.6;
  }
  .feature-link {
    display: inline-block;
    margin-top: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-green);
    text-decoration: none;
  }
  .feature-link:hover { text-decoration: underline; }

  /* COMPARISON */
  .comparison-section { margin-bottom: 3rem; }
  .table-wrap {
    overflow-x: auto;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
  }
  .comparison-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }
  .comparison-table th,
  .comparison-table td {
    padding: 0.625rem 0.875rem;
    text-align: left;
    border-bottom: 1px solid var(--color-border);
  }
  .comparison-table th {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-fg-muted);
    background: var(--color-bg-card);
  }
  .comparison-table td:not(.row-label) {
    font-family: var(--font-mono);
    color: var(--color-fg-secondary);
  }
  .row-label {
    color: var(--color-fg);
    font-weight: 500;
  }

  /* PRIVACY */
  .privacy-section { margin-bottom: 3rem; }
  .privacy-body {
    color: var(--color-fg-secondary);
    line-height: 1.7;
    padding: 1.25rem 1.5rem;
    background: var(--color-bg-card);
    border-left: 2px solid var(--color-green);
    border-radius: 0.25rem;
  }

  /* FAQ */
  .faq-section { margin-bottom: 3rem; }
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .faq-item {
    padding: 1rem 1.25rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
  }
  .faq-q {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1rem;
    color: var(--color-fg);
    margin-bottom: 0.375rem;
  }
  .faq-a {
    font-size: 0.9375rem;
    color: var(--color-fg-secondary);
    line-height: 1.65;
    margin: 0;
  }

  /* FOOTER */
  .product-footer {
    margin-top: 4rem;
    padding: 2rem;
    text-align: center;
    background:
      radial-gradient(ellipse at top, color-mix(in srgb, var(--color-green) 8%, transparent), transparent 60%),
      var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
  }
  .footer-h {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .footer-p {
    color: var(--color-fg-secondary);
    margin-bottom: 1.25rem;
    max-width: 40ch;
    margin-inline: auto;
  }
  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
  }
</style>
