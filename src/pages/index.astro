---
import { getCollection } from "astro:content";
import { execSync } from "child_process";
import BaseLayout from "../layouts/BaseLayout.astro";
import { TAG_COLORS } from "../lib/site";

const posts = (await getCollection("posts", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

let lastCommitSha: string | null = null;
let lastCommitDate: Date | null = null;
try {
  lastCommitSha = execSync("git rev-parse --short HEAD").toString().trim();
  const ts = execSync("git log -1 --format=%cI").toString().trim();
  lastCommitDate = new Date(ts);
} catch {
  lastCommitSha = null;
  lastCommitDate = null;
}

const buildTime = new Date();
---

<BaseLayout title="Jordan Newell" description="I build and operate the systems behind ambitious ventures." path="/">
  <section class="hero">
    <div class="hero-header">
      <img src="/profile-v5.jpg" alt="Jordan Newell" class="avatar" />
      <div class="hero-id">
        <h1 class="name">Jordan Newell</h1>
        <span class="hero-handle">rebuilding in public</span>
      </div>
    </div>
    <p class="tagline">I build and operate the systems behind ambitious ventures.</p>
    <p class="tagline-sub">Field notes from the rebuild — AI agents, self-hosted infra, crypto tooling, venture research. Written as it ships.</p>
    <div class="status-line">
      <span class="status-pulse"></span>
      Open to: advisory · security · ventures
    </div>
    <a href="/posts/day-0/" class="hero-cta">
      New here? Start with Day 0
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
    </a>
  </section>

  <section class="section">
    <div class="section-label">Live</div>
    <div class="live-grid">
      {lastCommitSha && lastCommitDate && (
        <div class="live-item">
          <div class="live-label">Last commit</div>
          <div class="live-value">
            <span class="mono-sha">{lastCommitSha}</span>
            <span class="live-relative" data-timestamp={lastCommitDate.toISOString()}>…</span>
          </div>
        </div>
      )}
      {posts[0] && (
        <div class="live-item">
          <div class="live-label">Latest post</div>
          <div class="live-value">
            <a href={`/posts/${posts[0].id}/`} class="live-link">{posts[0].data.title}</a>
            <span class="live-relative" data-timestamp={posts[0].data.pubDate.toISOString()}>…</span>
          </div>
        </div>
      )}
      <div class="live-item">
        <div class="live-label">Built</div>
        <div class="live-value">
          <span class="live-relative" data-timestamp={buildTime.toISOString()}>…</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-label">Core</div>
    <div class="expertise-grid">
      <div class="expertise-card">
        <div class="expertise-label">01</div>
        <div class="expertise-title">Build</div>
        <p class="expertise-desc">17 OpenClaw agents in production across 10 Tailscale-networked hosts.</p>
      </div>
      <div class="expertise-card">
        <div class="expertise-label">02</div>
        <div class="expertise-title">Fortify</div>
        <p class="expertise-desc">Synapse P0/P1 audit shipped. Funnel closed, 5 admins revoked, OTK reuse fixed.</p>
      </div>
      <div class="expertise-card">
        <div class="expertise-label">03</div>
        <div class="expertise-title">Scale</div>
        <p class="expertise-desc">Agent orchestration: Go + SQLite + Prometheus running the agent stack.</p>
      </div>
      <div class="expertise-card">
        <div class="expertise-label">04</div>
        <div class="expertise-title">Ship</div>
        <p class="expertise-desc">Crypto-key-classifier: 229 tests, 4 version tags. OpenClaw bug filed-and-fixed in 6 days.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-label">Latest from the blog</div>
    {posts.map((post) => (
      <a href={`/posts/${post.id}/`} class="post-item">
        <div class="post-date">
          {post.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
        </div>
        <div class="post-title">{post.data.title}</div>
        <div class="post-desc">{post.data.description}</div>
        <div class="post-tags">
          {post.data.tags.map((t) => (
            <span class="tag-pill" style={`color: ${TAG_COLORS[t] ?? "#A1A1AA"}`}>/{t}</span>
          ))}
        </div>
      </a>
    ))}
    <a href="/posts/" class="view-all">View all posts →</a>
  </section>

  <a href="mailto:hello@jordannewell.com" class="contact-bar">
    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
    Say hello
  </a>
</BaseLayout>

<style>
  .hero { margin-bottom: 48px; }
  .hero-header { display: flex; align-items: center; gap: 20px; margin-bottom: 20px; }
  .avatar {
    width: 72px; height: 72px; border-radius: 8px;
    object-fit: cover; border: 1px solid var(--color-border);
  }
  .hero-id { display: flex; flex-direction: column; gap: 4px; }
  .name {
    font-family: var(--font-display);
    font-size: 1.5rem; font-weight: 700; color: var(--color-fg);
    letter-spacing: -0.03em;
  }
  .hero-handle {
    font-family: var(--font-mono);
    font-size: 0.75rem; color: var(--color-fg-muted); letter-spacing: 0.04em;
  }
  .tagline {
    font-size: 1.05rem; color: var(--color-fg-secondary);
    line-height: 1.5; margin-bottom: 12px; font-weight: 400;
  }
  .tagline-sub {
    font-size: 0.95rem; color: var(--color-fg-muted);
    line-height: 1.55; margin-bottom: 16px; font-weight: 400;
  }
  .status-line {
    display: inline-flex; align-items: center; gap: 6px;
    font-family: var(--font-mono);
    font-size: 0.7rem; color: var(--color-green);
    letter-spacing: 0.1em; text-transform: uppercase;
    padding: 4px 8px;
    background: color-mix(in srgb, var(--color-green) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-green) 25%, transparent);
  }
  .status-pulse {
    width: 6px; height: 6px; background: var(--color-green);
    border-radius: 50%; animation: blink 2s ease-in-out infinite;
  }
  @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }

  .hero-cta {
    display: inline-flex; align-items: center; gap: 6px;
    margin-top: 20px; padding: 8px 14px;
    font-family: var(--font-mono);
    font-size: 0.8rem; color: var(--color-fg-secondary);
    text-decoration: none; border: 1px solid var(--color-border);
    background: var(--color-bg-card); letter-spacing: 0.04em;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
  }
  .hero-cta:hover {
    border-color: var(--color-border-light);
    color: var(--color-fg); background: var(--color-bg-card-hover);
  }
  .hero-cta svg { width: 12px; height: 12px; }

  .section { margin-bottom: 40px; }
  .section-label {
    font-family: var(--font-mono);
    font-size: 0.7rem; color: var(--color-fg-muted);
    letter-spacing: 0.15em; text-transform: uppercase;
    margin-bottom: 16px; display: flex; align-items: center; gap: 8px;
  }
  .section-label::before {
    content: ''; width: 12px; height: 1px; background: var(--color-fg-muted);
  }

  .expertise-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1px;
    background: var(--color-border); border: 1px solid var(--color-border);
  }
  .expertise-card {
    background: var(--color-bg-card); padding: 20px 18px; transition: background 0.15s;
  }
  .expertise-card:hover { background: var(--color-bg-card-hover); }
  .expertise-label {
    font-family: var(--font-mono);
    font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 8px;
  }
  .expertise-card:nth-child(1) .expertise-label { color: var(--color-blue); }
  .expertise-card:nth-child(2) .expertise-label { color: var(--color-amber); }
  .expertise-card:nth-child(3) .expertise-label { color: var(--color-violet); }
  .expertise-card:nth-child(4) .expertise-label { color: var(--color-green); }
  .expertise-title {
    font-family: var(--font-display);
    font-size: 1rem; font-weight: 600; color: var(--color-fg); margin-bottom: 6px;
  }
  .expertise-desc {
    font-size: 0.875rem; color: var(--color-fg-muted); line-height: 1.45;
  }

  .post-item {
    display: block; background: var(--color-bg-card);
    border: 1px solid var(--color-border); padding: 16px 18px;
    margin-bottom: 8px; text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
  }
  .post-item:hover { border-color: var(--color-border-light); background: var(--color-bg-card-hover); }
  .post-date {
    font-family: var(--font-mono);
    font-size: 0.7rem; color: var(--color-fg-muted);
    letter-spacing: 0.04em; margin-bottom: 6px;
  }
  .post-title {
    font-family: var(--font-display);
    font-size: 1rem; font-weight: 600; color: var(--color-fg);
    margin-bottom: 4px; line-height: 1.35;
  }
  .post-desc {
    font-size: 0.875rem; color: var(--color-fg-secondary);
    line-height: 1.5; margin-bottom: 8px;
  }
  .post-tags { display: flex; gap: 8px; flex-wrap: wrap; }
  .tag-pill {
    font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.04em;
  }
  .view-all {
    display: inline-block; margin-top: 12px;
    font-family: var(--font-mono);
    font-size: 0.75rem; color: var(--color-fg-muted); text-decoration: none;
    letter-spacing: 0.05em; text-transform: uppercase; transition: color 0.15s;
  }
  .view-all:hover { color: var(--color-fg); }

  .contact-bar {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    padding: 14px; background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    text-decoration: none; font-family: var(--font-mono);
    font-size: 0.8rem; color: var(--color-fg-secondary);
    letter-spacing: 0.04em; transition: all 0.15s;
  }
  .contact-bar:hover { border-color: var(--color-border-light); color: var(--color-fg); }
  .contact-bar svg { width: 14px; height: 14px; }

  .live-grid {
    display: grid; grid-template-columns: 1fr; gap: 1px;
    background: var(--color-border); border: 1px solid var(--color-border);
  }
  .live-item {
    background: var(--color-bg-card);
    padding: 14px 18px;
    display: flex; flex-direction: column; gap: 4px;
  }
  .live-label {
    font-family: var(--font-mono);
    font-size: 0.7rem; color: var(--color-fg-muted);
    letter-spacing: 0.15em; text-transform: uppercase;
  }
  .live-value {
    font-size: 0.95rem; color: var(--color-fg);
    display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap;
  }
  .mono-sha {
    font-family: var(--font-mono);
    font-size: 0.9rem; color: var(--color-green);
  }
  .live-link {
    color: var(--color-fg); text-decoration: none;
    border-bottom: 1px solid var(--color-border);
    transition: border-color 0.15s, color 0.15s;
  }
  .live-link:hover {
    color: var(--color-green); border-bottom-color: var(--color-green);
  }
  .live-relative {
    font-family: var(--font-mono);
    font-size: 0.75rem; color: var(--color-fg-muted);
  }

  @media (min-width: 480px) {
    .live-grid { grid-template-columns: 1fr 1fr; }
    .live-item:last-child { grid-column: span 2; }
  }

  @media (max-width: 480px) {
    .hero-header { gap: 16px; }
    .avatar { width: 64px; height: 64px; }
    .name { font-size: 1.3rem; }
  }
</style>
