# Deploy environment — copy to .env and fill in real values
# .env is gitignored. Never commit real values.
#
# Usage:
#   cp .env.example .env
#   # edit .env to fill in real values for your deploy target
#   bash scripts/deploy.sh

# SSH target. Examples:
#   user@your-host.example.com
#   user@100.64.0.1                 (Tailscale IP)
#   short-name                      (SSH alias from ~/.ssh/config)
REMOTE_HOST=user@host

# Absolute path to the web root on the remote host.
# This directory will be CLEARED AND REPLACED on every deploy.
REMOTE_PATH=/path/to/webroot

# Absolute path to a directory that holds timestamped backups.
# Created if it doesn't exist. One timestamped subdirectory per deploy.
BACKUP_DIR=/path/to/backups

# Optional — nginx access log path for scripts/check-llm-crawlers.sh
# Default works on most Debian/Ubuntu installs.
# LOG_PATH=/var/log/nginx/access.log
