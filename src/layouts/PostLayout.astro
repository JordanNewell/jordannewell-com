---
import BaseLayout from "./BaseLayout.astro";
import TagPill from "../components/TagPill.astro";
import { articleSchema } from "../lib/schema";
import type { CollectionEntry } from "astro:content";

const { post } = Astro.props as { post: CollectionEntry<"posts"> };
const { title, description, pubDate, updatedDate, tags, mode } = post.data;

const dateStr = pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const isMurphy = mode === "murphy";
const schema = [articleSchema({
  title,
  description,
  pubDate,
  updatedDate,
  slug: post.id,
  tags,
})];
---

<BaseLayout title={title} description={description} schema={schema}>
  <article class:list={["prose", isMurphy && "murphy-mode"]}>
    <header class="mb-10">
      <div class="flex items-center gap-3 text-sm font-mono text-fg-muted mb-3">
        <time datetime={pubDate.toISOString()}>{dateStr}</time>
        {tags.map((tag) => <TagPill tag={tag} />)}
      </div>
      <h1 class="font-display font-bold text-4xl md:text-5xl leading-tight mb-3">{title}</h1>
      <p class="text-xl text-fg-secondary">{description}</p>
    </header>
    <div class="post-content">
      <slot />
    </div>
  </article>
</BaseLayout>
