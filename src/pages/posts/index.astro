---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";

const posts = (await getCollection("posts", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
const totalWords = posts.reduce((sum, p) => sum + (p.body?.split(/\s+/).length ?? 0), 0);
const recentYear = posts.length > 0 ? new Date(posts[0].data.pubDate).getFullYear() : "—";
---

<BaseLayout title="Posts" description="Field notes from the operator's desk.">
  <header class="posts-hero">
    <div class="posts-hero-glow"></div>
    <div class="posts-hero-content">
      <span class="posts-hero-eyebrow">// field notes</span>
      <h1 class="posts-hero-title">/posts</h1>
      <p class="posts-hero-tagline">
        Field notes from an operator shipping in public across sectors.
      </p>
      <p class="posts-hero-desc">
        Sectors are tags; the operator is the brand. Post-mortems, decision logs, debug stories, tooling write-ups — the discipline is that they get written, in public, regardless of whether the week was a win.
      </p>
      <div class="posts-hero-stats">
        <span class="stat-pill"><span class="stat-num">{posts.length}</span> posts</span>
        <span class="stat-pill"><span class="stat-num">{allTags.length}</span> tags</span>
        <span class="stat-pill"><span class="stat-num">{totalWords.toLocaleString()}</span> words</span>
        <span class="stat-pill"><span class="stat-num">{recentYear}</span> latest</span>
      </div>
      <nav class="posts-hero-tags">
        <a href="/" class="tag-link">all</a>
        {allTags.map((tag) => (
          <a href={`/tags/${tag}`} class="tag-link">/{tag}</a>
        ))}
      </nav>
    </div>
  </header>

  <div class="space-y-4">
    {posts.map((post) => <PostCard post={post} />)}
  </div>

  <p class="mt-10 text-sm font-mono text-fg-muted">
    <a href="/rss.xml" class="hover:text-green">subscribe via RSS</a>
    · <a href="/feed.json" class="hover:text-green">JSON feed</a>
    · <a href="/ai-feed.json" class="hover:text-green">AI/LLM feed</a>
  </p>
</BaseLayout>

<style>
  .posts-hero {
    position: relative;
    padding: 2.5rem 2rem;
    margin-bottom: 2.5rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    overflow: hidden;
  }
  .posts-hero-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 70% 60% at 100% 0%, rgba(244, 114, 182, 0.22), transparent 60%),
      radial-gradient(ellipse 60% 70% at 0% 100%, color-mix(in srgb, var(--color-green) 12%, transparent), transparent 55%);
  }
  .posts-hero-content { position: relative; z-index: 1; }
  .posts-hero-eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-green);
    margin-bottom: 0.75rem;
  }
  .posts-hero-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2.25rem, 5vw, 3.25rem);
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--color-fg);
    margin-bottom: 0.75rem;
  }
  .posts-hero-tagline {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    color: #F472B6;
    line-height: 1.3;
    margin-bottom: 0.625rem;
    max-width: 60ch;
  }
  .posts-hero-desc {
    font-size: 1rem;
    color: var(--color-fg-secondary);
    line-height: 1.65;
    max-width: 65ch;
    margin-bottom: 1.5rem;
  }
  .posts-hero-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
    margin-bottom: 1.25rem;
  }
  .stat-pill {
    display: inline-flex;
    align-items: baseline;
    gap: 0.375rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.375rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    background: color-mix(in srgb, var(--color-bg) 50%, transparent);
  }
  .stat-num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--color-fg);
    letter-spacing: 0;
    text-transform: none;
  }
  .posts-hero-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }
  .tag-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-fg-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .tag-link:hover { color: #F472B6; }
</style>
