---
import BaseLayout from "./BaseLayout.astro";
import TagPill from "../components/TagPill.astro";
import SeriesBadge from "../components/SeriesBadge.astro";
import EraBadge from "../components/EraBadge.astro";
import KindBadge from "../components/KindBadge.astro";
import { articleSchema } from "../lib/schema";
import type { CollectionEntry } from "astro:content";

const { post } = Astro.props as { post: CollectionEntry<"posts"> };
const { title, description, pubDate, updatedDate, tags, mode, series, era, kind } = post.data;

const dateStr = pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: "UTC",
});

const isMurphy = mode === "murphy";
const schema = [articleSchema({
  title,
  description,
  pubDate,
  updatedDate,
  slug: post.id,
  tags,
})];
---

<BaseLayout title={title} description={description} schema={schema}>
  <article class:list={["prose", isMurphy && "murphy-mode"]}>
    <header class="mb-10">
      <div class="flex items-center gap-3 text-sm font-mono text-fg-muted mb-3 flex-wrap">
        <time datetime={pubDate.toISOString()}>{dateStr}</time>
        {tags.map((tag) => <TagPill tag={tag} />)}
        {kind && <KindBadge kind={kind} />}
      </div>
      <h1 class="font-display font-bold text-4xl md:text-5xl leading-tight mb-3">{title}</h1>
      <p class="text-xl text-fg-secondary mb-3">{description}</p>
      {era && <div class="mb-3"><EraBadge era={era} /></div>}
      {series.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {series.map((slug) => <SeriesBadge slug={slug} />)}
        </div>
      )}
    </header>
    <div class="post-content">
      <slot />
    </div>
  </article>
</BaseLayout>
